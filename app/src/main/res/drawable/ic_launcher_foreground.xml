<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Bold, polished 3D fluid droplet styled beautifully -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 54,23 C 40,41 33,50 33,63 A 21,21 0 0,0 75,63 C 75,50 68,41 54,23 Z" />
        
    <!-- Sleek inner gradient shadow mapping for premium visual depth -->
    <path
        android:pathData="M 54,23 C 40,41 33,50 33,63 A 21,21 0 0,0 75,63 C 75,50 68,41 54,23 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="23"
                android:endX="54"
                android:endY="84">
                <item android:offset="0.0" android:color="#93C5FD" />
                <item android:offset="1.0" android:color="#2563EB" />
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- Curved glass shine reflection on top-left of the droplet -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.45"
        android:pathData="M 43,58 C 40,54 44,44 48,39 C 47,44 45,51 47,56 C 48,59 45,59 43,58 Z" />

    <!-- Tiny cute sparkle on top-right -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.75"
        android:pathData="M 64,48 A 2,2 0 1,1 60,48 A 2,2 0 1,1 64,48" />
</vector>
